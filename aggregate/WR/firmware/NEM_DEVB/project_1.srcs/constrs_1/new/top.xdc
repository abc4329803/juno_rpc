#Local CLK
set_property PACKAGE_PIN G13 [get_ports EXT_CLK] 
set_property IOSTANDARD LVCMOS33 [get_ports EXT_CLK]
create_clock -period 8.000 -name EXT_CLK [get_ports EXT_CLK]

