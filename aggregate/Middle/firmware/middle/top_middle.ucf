# ============================================================
# 2. IOB约束 - ISERDES不能使用IOB=FORCE（与BUFPLL架构冲突＄17
# ============================================================
# ISERDES必须使用ILOGIC，不能强制到IOB
#INST "gen_rx[*]*u_iserdes_s6" IOB = FORCE;

# ODDR2输出可以保持在IOB丄17
#INST "gen_rx[*]*ODDR2_FWDCLK" IOB = FORCE;
#INST "gen_rx[*]*oddr2_data_fwd" IOB = FORCE;
#
## JTAG ODDR2输出保持在IOB
#INST "gen_rx[*]*u_oddr2_tck" IOB = FORCE;
#INST "gen_rx[*]*u_oddr2_tms" IOB = FORCE;
#INST "gen_rx[*]*u_oddr2_tdi" IOB = FORCE;

# ============================================================
# Spartan-6 箢化时钟架构：仅使甄17 BUFG
# ============================================================
# 由于引脚分散在不各17 Bank/half bank，无法使甄17 BUFIO2/BUFPLL
# 使用全局时钟 BUFG 驱动扢朄17 ISERDES＄17250MHz 圄17 BUFG 能力范围内）

# 允许 BUFG 驱动 ISERDES.IOCE 非时钟引脄17
#PIN "bufg_strobe.O" CLOCK_DEDICATED_ROUTE = FALSE;

# 定义时序组17
NET "clk_62M5" TNM_NET = "TNM_GCLK";
#NET "clk_250M" TNM_NET = "TNM_CLK_250M";
#NET "serdes_strobe" TNM_NET = "TNM_STROBE";

# 跨时钟域约束
#TIMESPEC TS_GCLK_TO_250M = FROM "TNM_GCLK" TO "TNM_CLK_250M" TIG;
#TIMESPEC TS_250M_TO_GCLK = FROM "TNM_CLK_250M" TO "TNM_GCLK" TIG;

#NET "SLAVE_TCK" TNM_NET = "TCK_TREE";
NET "FTCK_LVDS33_P" TNM_NET = "JTAG_IN_GRP";
NET "FTMS_LVDS33_P" TNM_NET = "JTAG_IN_GRP";
NET "FTDI_LVDS33_P" TNM_NET = "JTAG_IN_GRP";
TIMESPEC TS_TCK_FANOUT = FROM "JTAG_IN_GRP" TO "TCK_LVCMOS33*" 5 ns;
TIMESPEC TS_TCK_FANOUT = FROM "JTAG_IN_GRP" TO "TMS_LVCMOS33*" 5 ns;
TIMESPEC TS_TCK_FANOUT = FROM "JTAG_IN_GRP" TO "TDI_LVCMOS33*" 5 ns;

INST "tck_bufg" TNM_NET = "TCK_INTERNAL";
TIMESPEC TS_TCK_SKEW = FROM "TCK_INTERNAL" TO "TCK_LVCMOS33" 2 ns;

NET "FTDO_LVDS33_P*" TNM_NET = "TDO_COLLECT";
TIMESPEC TS_TDO_BACK = FROM "TDO_COLLECT" TO "FTDO_LVDS33_P" 5 ns;

#PIN "BUFG_clk_62M5_gloabal.O" CLOCK_DEDICATED_ROUTE = FALSE; 

INST "PLL_BASE_0" LOC = "PLL_ADV_X0Y1";
