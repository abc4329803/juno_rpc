NET "TCK_LVCMOS33[2]" LOC = E1 | IOSTANDARD = LVCMOS33 | DRIVE = 16 | IOB = TRUE;
NET "TMS_LVCMOS33[2]" LOC = F1 | IOSTANDARD = LVCMOS33 | DRIVE = 16 | IOB = TRUE;
NET "TDI_LVCMOS33[2]" LOC = G1 | IOSTANDARD = LVCMOS33 | DRIVE = 16 | IOB = TRUE;
NET "TDO_LVCMOS33[2]" LOC = D1 | IOSTANDARD = LVCMOS33 | IOB = TRUE;

NET "TCK_LVCMOS33[3]" LOC = J1 | IOSTANDARD = LVCMOS33 | DRIVE = 16 | IOB = TRUE;
NET "TMS_LVCMOS33[3]" LOC = K1 | IOSTANDARD = LVCMOS33 | DRIVE = 16 | IOB = TRUE;
NET "TDI_LVCMOS33[3]" LOC = L1 | IOSTANDARD = LVCMOS33 | DRIVE = 16 | IOB = TRUE;
NET "TDO_LVCMOS33[3]" LOC = H1 | IOSTANDARD = LVCMOS33 | IOB = TRUE;

NET "TCK_LVCMOS33[4]" LOC = N1 | IOSTANDARD = LVCMOS33 | DRIVE = 16 | IOB = TRUE;
NET "TMS_LVCMOS33[4]" LOC = P1 | IOSTANDARD = LVCMOS33 | DRIVE = 16 | IOB = TRUE;
NET "TDI_LVCMOS33[4]" LOC = R1 | IOSTANDARD = LVCMOS33 | DRIVE = 16 | IOB = TRUE;
NET "TDO_LVCMOS33[4]" LOC = M1 | IOSTANDARD = LVCMOS33 | IOB = TRUE;

NET "TCK_LVCMOS33[5]" LOC = R14 | IOSTANDARD = LVCMOS33 | DRIVE = 16 | IOB = TRUE;
NET "TMS_LVCMOS33[5]" LOC = R15 | IOSTANDARD = LVCMOS33 | DRIVE = 16 | IOB = TRUE;
NET "TDI_LVCMOS33[5]" LOC = P15 | IOSTANDARD = LVCMOS33 | DRIVE = 16 | IOB = TRUE;
NET "TDO_LVCMOS33[5]" LOC = R12 | IOSTANDARD = LVCMOS33 | IOB = TRUE;

NET "TCK_LVCMOS33[6]" LOC = T13 | IOSTANDARD = LVCMOS33 | DRIVE = 16 | IOB = TRUE;
NET "TMS_LVCMOS33[6]" LOC = T14 | IOSTANDARD = LVCMOS33 | DRIVE = 16 | IOB = TRUE;
NET "TDI_LVCMOS33[6]" LOC = T15 | IOSTANDARD = LVCMOS33 | DRIVE = 16 | IOB = TRUE;
NET "TDO_LVCMOS33[6]" LOC = T12 | IOSTANDARD = LVCMOS33 | IOB = TRUE;

#NET "RESET_LVDS33_P[1]" LOC = M12 | IOSTANDARD = LVDS_33;
#NET "CLK_LVDS33_P[1]" LOC = D6 | IOSTANDARD = LVDS_33;
#NET "DATA_LVDS33_P[1]" LOC = F9 | IOSTANDARD = LVDS_33;
#NET "FB_LVDS33_P[1]" LOC = D8 | IOSTANDARD = LVCMOS33;
#NET "FB_LVDS33_N[1]" LOC = C8 | IOSTANDARD = LVCMOS33;


PIN "tck_bufg.O" CLOCK_DEDICATED_ROUTE = FALSE;

NET "RESET_LVDS33_P[2]" LOC = P7 | IOSTANDARD = LVDS_33;
# pin reverse
NET "CLK_LVDS33_P[2]" LOC = M6 | IOSTANDARD = LVDS_33;
NET "DATA_LVDS33_P[2]" LOC = D5 | IOSTANDARD = LVDS_33;
# pin reverse
NET "FB_LVDS33_P[2]" LOC = P5 | IOSTANDARD = LVCMOS33;
NET "FB_LVDS33_N[2]" LOC = N5 | IOSTANDARD = LVCMOS33;

# pin reverse
NET "RESET_LVDS33_P[3]" LOC = N12 | IOSTANDARD = LVDS_33;
# pin reverse
NET "CLK_LVDS33_P[3]" LOC = N11 | IOSTANDARD = LVDS_33;
# pin reverse
NET "DATA_LVDS33_P[3]" LOC = N9 | IOSTANDARD = LVDS_33;
# pin reverse
NET "FB_LVDS33_P[3]" LOC = M10 | IOSTANDARD = LVCMOS33;
NET "FB_LVDS33_N[3]" LOC = L10 | IOSTANDARD = LVCMOS33;

# pin reverse
NET "RESET_LVDS33_P[4]" LOC = R3 | IOSTANDARD = LVDS_33;
NET "CLK_LVDS33_P[4]" LOC = C4 | IOSTANDARD = LVDS_33;
NET "DATA_LVDS33_P[4]" LOC = B6 | IOSTANDARD = LVDS_33;
NET "FB_LVDS33_P[4]" LOC = B5 | IOSTANDARD = LVCMOS33;
NET "FB_LVDS33_N[4]" LOC = A5 | IOSTANDARD = LVCMOS33;
# pin reverse
NET "RESET_LVDS33_P[5]" LOC = R7 | IOSTANDARD = LVDS_33;
# pin reverse
NET "CLK_LVDS33_P[5]" LOC = P6 | IOSTANDARD = LVDS_33;
# pin reverse
NET "DATA_LVDS33_P[5]" LOC = P4 | IOSTANDARD = LVDS_33;
# pin reverse
NET "FB_LVDS33_P[5]" LOC = T5 | IOSTANDARD = LVCMOS33;
NET "FB_LVDS33_N[5]" LOC = R5 | IOSTANDARD = LVCMOS33;
# pin reverse
NET "RESET_LVDS33_P[6]" LOC = R11 | IOSTANDARD = LVDS_33;
# pin reverse
NET "CLK_LVDS33_P[6]" LOC = P10 | IOSTANDARD = LVDS_33;
# pin reverse
NET "DATA_LVDS33_P[6]" LOC = P8 | IOSTANDARD = LVDS_33;
# pin reverse
NET "FB_LVDS33_P[6]" LOC = T9 | IOSTANDARD = LVCMOS33;
NET "FB_LVDS33_N[6]" LOC = R9 | IOSTANDARD = LVCMOS33;
CONFIG VCCAUX = 3.3;
# WR

NET "FTCK_LVDS33_P" LOC = C9 | IOSTANDARD = LVDS_33;
NET "FTCK_LVDS33_N" LOC = A9 | IOSTANDARD = LVDS_33;
NET "FTMS_LVDS33_P" LOC = C11 | IOSTANDARD = LVDS_33;
NET "FTMS_LVDS33_N" LOC = A11 | IOSTANDARD = LVDS_33;
NET "FTDI_LVDS33_P" LOC = B10 | IOSTANDARD = LVDS_33;
NET "FTDI_LVDS33_N" LOC = A10 | IOSTANDARD = LVDS_33;
NET "FTDO_LVDS33_P" LOC = B12 | IOSTANDARD = LVDS_33;
NET "FTDO_LVDS33_N" LOC = A12 | IOSTANDARD = LVDS_33;

NET "WR_RESET_IN_P" LOC = E10 | IOSTANDARD = LVDS_33;
NET "WR_RESET_IN_N" LOC = C10 | IOSTANDARD = LVDS_33;
NET "WR_CLK_IN_P" LOC = E7 | IOSTANDARD = LVDS_33;
NET "WR_CLK_IN_N" LOC = E8 | IOSTANDARD = LVDS_33;
NET "WR_DATA_OUT_P" LOC = C7 | IOSTANDARD = LVDS_33;
NET "WR_DATA_OUT_N" LOC = A7 | IOSTANDARD = LVDS_33;
NET "WR_FB_OUT_P" LOC = B8 | IOSTANDARD = LVDS_33;
NET "WR_FB_OUT_N" LOC = A8 | IOSTANDARD = LVDS_33;

NET "WR_CLK_IN_P" TNM_NET = "WR_CLK_IN_P";
TIMESPEC TS_WR_CLK_IN_P = PERIOD "WR_CLK_IN_P" 62.5 MHz HIGH 50 %;

NET "WR_RESET_IN_P" PULLDOWN;
NET "WR_RESET_IN_N" PULLDOWN;
# NET "WR_CLK_IN_P" PULLDOWN;
# NET "WR_CLK_IN_N" PULLDOWN;


