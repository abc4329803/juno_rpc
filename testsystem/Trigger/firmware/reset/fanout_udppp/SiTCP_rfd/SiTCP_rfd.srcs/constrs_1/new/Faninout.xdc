##################################
# System
set_property PACKAGE_PIN E10 [get_ports INIT_CLK_P]
set_property IOSTANDARD LVDS_25 [get_ports INIT_CLK_P]
create_clock -period 10.000 -name INIT_CLK_P [get_ports INIT_CLK_P]

set_property PACKAGE_PIN C12 [get_ports clk_p_sitcp]
set_property IOSTANDARD LVDS_25 [get_ports clk_p_sitcp]
create_clock -period 10.000 -name INIT_CLK_P [get_ports clk_p_sitcp]

set_property PACKAGE_PIN E10 [get_ports EXT_CLK]
set_property IOSTANDARD LVCMOS25 [get_ports EXT_CLK]
create_clock -period 8.000 -name INIT_CLK_P [get_ports EXT_CLK]

