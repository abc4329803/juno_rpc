set_property BITSTREAM.CONFIG.SPI_BUSWIDTH 4 [current_design]

set_property PULLDOWN true [get_ports {FPGA_OUT[0]}]
set_property PULLDOWN true [get_ports {FPGA_OUT[1]}]


set_property DRIVE 12 [get_ports {FPGA_OUT[0]}]
set_property DRIVE 12 [get_ports {FPGA_OUT[1]}]
set_property DRIVE 12 [get_ports {CLK_OUT[0]}]
set_property DRIVE 12 [get_ports {CLK_OUT[1]}]

set_max_delay -from [get_pins SiTCP_rfd_top/RBCP_REG/TDC_RST_ON_reg/C] -to [get_pins TDC_RST_reg/D] 4.0
set_property C_CLK_INPUT_FREQ_HZ 300000000 [get_debug_cores dbg_hub]
set_property C_ENABLE_CLK_DIVIDER false [get_debug_cores dbg_hub]
set_property C_USER_SCAN_CHAIN 1 [get_debug_cores dbg_hub]
connect_debug_port dbg_hub/clk [get_nets clk125]
